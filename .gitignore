# ─────────────────────────────────────────────────────────────────────────────
# CodeSage AI — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ─── Secrets & Environment ───────────────────────────────────────────────────
.env
*.env.local
!.env.example

# ─── Java / Maven ────────────────────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
.mvn/repository/
.mvn/wrapper/maven-wrapper.jar

# ─── IDE ─────────────────────────────────────────────────────────────────────
.idea/
*.iml
.eclipse/
.classpath
.project
.settings/
*.launch
.vscode/settings.json
*.suo
*.user
*.sln.docstates

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ─── Node / Frontend ─────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.*.local
frontend/coverage/

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Docker ──────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ─── Test Artefacts ──────────────────────────────────────────────────────────
backend/target/surefire-reports/
backend/target/failsafe-reports/

# ─── Temp ────────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
arch_extracted.txt
