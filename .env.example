# ─────────────────────────────────────────────────────────────────────────────
# CodeSage AI — Environment Variables Template
#
# USAGE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual values in .env
#   3. NEVER commit .env to version control (it's in .gitignore)
#
# All services read these via Docker Compose variable substitution.
# Spring Boot reads them directly when running outside Docker.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Spring Profile ───────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=codesage_db
DB_USERNAME=codesage_user
DB_PASSWORD=changeme_strong_password_here

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank for no-password local dev, set for prod
REDIS_PASSWORD=

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=codesage_vectors

# ─── Backend Server ───────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── App ──────────────────────────────────────────────────────────────────────
APP_VERSION=1.0.0-SNAPSHOT
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Gemini AI (Sprint 5) ─────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── GitHub OAuth (Sprint 2 & 3) ─────────────────────────────────────────────
# 1. Register OAuth App: https://github.com/settings/applications/new
# 2. Homepage URL: http://localhost:5173
# 3. Callback URL: http://localhost:5173/auth/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Used to validate incoming webhook payloads (Sprint 3)
GITHUB_WEBHOOK_SECRET=replace_with_your_webhook_secret

# AI & Embeddings (Sprint 5)
GEMINI_API_KEY=your_gemini_api_key_here
CHROMA_URL=http://localhost:8000_here
GITHUB_CALLBACK_URL=http://localhost:8080/api/v1/auth/github/callback

# ─── JWT (Sprint 2) ───────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_minimum_256_bits
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7
